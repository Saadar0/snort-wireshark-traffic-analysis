# ============================================================
# LOCAL SNORT 3 RULES - Cybersecurity Lab
# HOME_NET     = 192.168.10.0/24
# EXTERNAL_NET = any
# ============================================================

# ============================================================
# 1. SSH BRUTE FORCE DETECTION
# Detects repeated SSH connection attempts from the same source.
# ============================================================

alert tcp any any -> $HOME_NET 22 (
    msg:"SSH Brute Force Attempt";
    flow:to_server;
    flags:S;
    detection_filter:track by_src, count 50, seconds 60;
    classtype:attempted-admin;
    sid:1000001;
    rev:1;
)

# ============================================================
# 2. SYN FLOOD DETECTION
# Detects excessive SYN packets to the same destination.
# ============================================================

alert tcp any any -> $HOME_NET any (
    msg:"Possible SYN Flood Attack";
    flags:S;
    flow:stateless;
    detection_filter:track by_dst, count 1000, seconds 5;
    classtype:attempted-dos;
    sid:1000002;
    rev:1;
)

# ============================================================
# 3. HIGH-FREQUENCY DNS QUERIES
# Detects abnormal DNS request rates from one host.
# ============================================================

alert udp $HOME_NET any -> any 53 (
    msg:"High Frequency DNS Queries";
    detection_filter:track by_src, count 100, seconds 60;
    classtype:policy-violation;
    sid:1000003;
    rev:1;
)

# ============================================================
# 4. DNS TUNNELING DETECTION
# Detects unusually large DNS queries.
# ============================================================

alert udp $HOME_NET any -> any 53 (
    msg:"DNS Unusually Large Query - Possible Tunneling";
    dsize:>150;
    classtype:policy-violation;
    sid:1000004;
    rev:1;
)

# ============================================================
# 5. ICMP COVERT CHANNEL DETECTION
# Detects repeated oversized ICMP Echo Requests.
# ============================================================

alert icmp $HOME_NET any -> any any (
    msg:"Possible ICMP Exfiltration";
    itype:8;
    dsize:>500;
    detection_filter:track by_src, count 5, seconds 30;
    classtype:data-theft;
    sid:1000005;
    rev:1;
)

# ============================================================
# 6. TCP SYN PORT SCAN DETECTION
# Detects repeated SYN packets from one source.
# ============================================================

alert tcp any any -> $HOME_NET any (
    msg:"Possible TCP SYN Port Scan";
    flags:S;
    detection_filter:track by_src, count 20, seconds 10;
    classtype:attempted-recon;
    sid:1000006;
    rev:1;
)

# ============================================================
# 7. TCP NULL SCAN DETECTION
# Detects TCP packets with no flags set.
# ============================================================

alert tcp any any -> $HOME_NET any (
    msg:"PORT SCAN TCP NULL Scan Detected";
    flags:0;
    classtype:network-scan;
    sid:1000007;
    rev:1;
)

# ============================================================
# 8. TCP XMAS SCAN DETECTION
# Detects FIN, PSH and URG flags set simultaneously.
# ============================================================

alert tcp any any -> $HOME_NET any (
    msg:"PORT SCAN TCP XMAS Scan Detected";
    flags:FPU;
    flow:stateless;
    classtype:network-scan;
    sid:1000008;
    rev:1;
)

# ============================================================
# 9. FTP DATA EXFILTRATION DETECTION
# Detects outbound FTP connections.
# ============================================================

alert tcp $HOME_NET any -> $EXTERNAL_NET 21 (
    msg:"EXFILTRATION Outbound FTP";
    flow:to_server,established;
    classtype:data-theft;
    sid:1000009;
    rev:1;
)

# ============================================================
# 10. SQL INJECTION DETECTION
# Detects common SQL injection patterns in HTTP requests.
# ============================================================

alert http any any -> $HOME_NET 80 (
    msg:"WEB-ATTACK SQL Injection Attempt";
    flow:to_server,established;
    http_uri;
    pcre:"/(\%27|'|--|\%23|#).*(union|select|or|and|sleep|benchmark)/i";
    classtype:web-application-attack;
    sid:1000010;
    rev:1;
)

# ============================================================
# 11. COMMAND INJECTION DETECTION
# Detects common shell metacharacters in HTTP requests.
# ============================================================

alert http any any -> $HOME_NET 80 (
    msg:"WEB-ATTACK Command Injection";
    flow:to_server,established;
    http_uri;
    pcre:"/(\;|\||&&|\$\(|`)/";
    classtype:web-application-attack;
    sid:1000011;
    rev:1;
)

# ============================================================
# 12. ACCESS TO /etc/passwd DETECTION
# Detects requests attempting to access the passwd file.
# ============================================================

alert http any any -> $HOME_NET 80 (
    msg:"WEB-ATTACK Access to passwd";
    flow:to_server,established;
    http_uri;
    content:"/etc/passwd";
    classtype:web-application-attack;
    sid:1000012;
    rev:1;
)

# ============================================================
# 13. SUSPICIOUS USER-AGENT DETECTION
# Detects the sqlmap User-Agent.
# ============================================================

alert http any any -> $HOME_NET 80 (
    msg:"HTTP Suspicious User-Agent";
    flow:to_server,established;
    http_header;
    content:"sqlmap";
    classtype:web-application-attack;
    sid:1000013;
    rev:1;
)
